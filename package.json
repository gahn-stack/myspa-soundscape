{
  "name": "soundscape",
  "version": "1.0.0-SNAPSHOT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "build-staging": "vite build --mode staging --sourcemap",
    "build-prod": "vite build --mode prod",
    "type-check": "vue-tsc --build --force",
    "lint": "biome check .",
    "format": "biome check --write ."
  },
  "dependencies": {
    "pinia": "^2.1.7",
    "vue": "^3.3.11",
    "vue-router": "^4.2.5",
    "vue-i18n": "^9.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.4",
    "@tailwindcss/vite": "^4.1.0",
    "vite-plugin-pwa": "^0.21.2",
    "@types/node": "18.18.0",
    "@vitejs/plugin-vue": "^4.5.2",
    "@vue/test-utils": "^2.4.3",
    "npm-run-all2": "^6.1.1",
    "tailwindcss": "^4.1.0",
    "typescript": "~5.3.0",
    "vite": "^5.0.10",
    "vite-plugin-compression2": "^1.4.0",
    "vitest": "^1.0.4",
    "vue-tsc": "^1.6.5"
  }
}
